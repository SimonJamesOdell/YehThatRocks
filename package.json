{
  "name": "yehthatrocks",
  "private": true,
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "prepare": "git config core.hooksPath .githooks && node -e \"const fs=require('fs'); const p='.githooks/pre-commit'; if(process.platform!=='win32'){try{fs.chmodSync(p,0o755)}catch(e){}}\"",
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "tunnel:host": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-ssh-tunnel-host.ps1",
    "prisma:format": "prisma format",
    "prisma:generate": "cross-env PRISMA_GENERATE_NO_ENGINE= prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:status": "prisma migrate status",
    "audit:embedability": "node scripts/audit-video-embedability.js",
    "audit:embedability:pool": "node scripts/audit-video-embedability.js --limit=200 --concurrency=8 --exhaustive",
    "audit:embedability:all": "node scripts/audit-video-embedability.js --all --limit=1000 --concurrency=8 --exhaustive",
    "audit:catalog": "node scripts/audit-catalog-integrity.js",
    "dedupe:videos": "node scripts/prune-duplicate-videos.js",
    "dedupe:videos:apply": "node scripts/prune-duplicate-videos.js --apply",
    "dedupe:videos:enforce": "node scripts/prune-duplicate-videos.js --enforce-unique",
    "dedupe:videos:apply:enforce": "node scripts/prune-duplicate-videos.js --apply --enforce-unique",
    "scan:non-music": "node scripts/scan-non-music-candidates.js",
    "scan:non-music:review": "node scripts/scan-non-music-candidates.js --scan-all=1 --scope=all-videos --max-candidates=0 --batch-size=3000 --min-score=3",
    "scan:non-music:strict": "node scripts/scan-non-music-candidates.js --min-score=5 --max-candidates=1000",
    "scan:non-music:all": "node scripts/scan-non-music-candidates.js --scan-all=1 --max-candidates=2000 --batch-size=3000",
    "scan:non-music:every-row": "node scripts/scan-non-music-candidates.js --scan-all=1 --scope=all-videos --max-candidates=0 --batch-size=3000",
    "scan:non-music:every-row:apply-local": "node scripts/scan-non-music-candidates.js --scan-all=1 --scope=all-videos --max-candidates=0 --batch-size=3000 --apply-local=1 --confirm-delete=YES",
    "scan:non-music:build-delete-sql": "node scripts/build-non-music-delete-sql.js",
    "fix:reversed-artist-track": "node scripts/fix-reversed-artist-track.js",
    "fix:reversed-artist-track:apply": "node scripts/fix-reversed-artist-track.js --apply --confirm=SWAP_ARTIST_TRACK",
    "repair:video-metadata": "node scripts/repair-video-metadata.js",
    "repair:video-metadata:apply": "node scripts/repair-video-metadata.js --apply --confirm=REPAIR_VIDEO_METADATA",
    "prune:unavailable:all": "node scripts/audit-video-embedability.js --all --limit=1000 --concurrency=8 --exhaustive --prune-unavailable",
    "rebuild:artist-stats": "node scripts/rebuild-artist-stats.js",
    "backfill:related": "node scripts/backfill-related-links.js",
    "verify:categories": "node scripts/verify-categories-invariants.js",
    "verify:categories:api": "node scripts/verify-categories-invariants.js --check-api",
    "verify:artists-ui": "node scripts/verify-artists-ui-invariants.js",
    "verify:top100-ui": "node scripts/verify-top100-ui-invariants.js",
    "verify:playlists-ui": "node scripts/verify-playlists-ui-invariants.js",
    "verify:playlists:api": "node scripts/verify-playlists-api-smoke.js",
    "verify:core-experience": "node scripts/verify-core-experience-invariants.js",
      "verify:player-core": "node scripts/verify-player-core-invariants.js",
      "verify:overlay-routing": "node scripts/verify-overlay-routing-invariants.js",
      "verify:new-videos": "node scripts/verify-new-videos-invariants.js",
    "verify:core-experience:api": "node scripts/verify-core-experience-api-smoke.js",
    "verify:auth": "node scripts/verify-auth-invariants.js",
    "verify:admin": "node scripts/verify-admin-invariants.js",
    "verify:favourites": "node scripts/verify-favourites-invariants.js",
    "verify:history-ui": "node scripts/verify-history-ui-invariants.js",
    "verify:watch-next-and-new": "node scripts/verify-watch-next-and-new-invariants.js",
    "verify:thumbnail-preflight": "node scripts/verify-thumbnail-preflight-invariants.js",
    "verify:hidden-videos": "node scripts/verify-hidden-videos-invariants.js",
    "verify:search": "node scripts/verify-search-invariants.js",
    "verify:classification": "node scripts/verify-classification-invariants.js",
    "verify:no-seed-fallbacks": "node scripts/verify-no-seed-fallbacks-invariants.js",
    "verify:delivery-cache": "node scripts/verify-cache-delivery-invariants.js",
    "verify:budget-guardrails": "node scripts/verify-budget-guardrails.js",
    "verify:queue-behavior": "npm -w web run test -- components/use-next-track-decision.test.ts components/use-temporary-queue-controller.component.test.tsx",
    "verify:compile": "npm run build",
    "verify:auth:api": "node scripts/verify-auth-api-smoke.js",
    "monitor:performance": "node scripts/monitor-performance.js",
    "facebook:group-share": "node scripts/facebook-group-autoshare.js",
    "facebook:group-share:dry-run": "node scripts/facebook-group-autoshare.js --dry-run",
    "reddit:subreddit-share": "node scripts/reddit-subreddit-autoshare.js",
    "reddit:subreddit-share:dry-run": "node scripts/reddit-subreddit-autoshare.js --dry-run",
    "verify:magazine": "node scripts/verify-magazine-invariants.js",
    "verify:shell-decomposition": "node scripts/verify-shell-decomposition-invariants.js",
    "verify:ui-regressions": "npm run verify:artists-ui && npm run verify:top100-ui && npm run verify:playlists-ui && npm run verify:core-experience && npm run verify:player-core && npm run verify:overlay-routing && npm run verify:new-videos && npm run verify:categories && npm run verify:thumbnail-preflight && npm run verify:auth && npm run verify:admin && npm run verify:favourites && npm run verify:history-ui && npm run verify:watch-next-and-new && npm run verify:hidden-videos && npm run verify:search && npm run verify:classification && npm run verify:no-seed-fallbacks && npm run verify:delivery-cache && npm run verify:budget-guardrails && npm run verify:queue-behavior && npm run verify:magazine && npm run verify:shell-decomposition",
    "verify:invariants": "npm run verify:compile && npm run verify:ui-regressions",
    "verify:invariants:api": "npm run verify:core-experience:api && npm run verify:playlists:api && npm run verify:categories:api && npm run verify:auth:api"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "prisma": "^6.7.0",
    "turbo": "^2.5.0"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3"
  }
}
