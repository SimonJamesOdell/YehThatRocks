DATABASE_URL="mysql://user:password@localhost:3306/yeh"
AUTH_JWT_SECRET="replace-with-a-random-32-plus-character-secret"
APP_URL="http://localhost:3000"

# Admin panel access control (required for production; see SECURITY_AUDIT_ADMIN.md)
# Choose ONE of:
#   1. Email-based (less secure): ADMIN_EMAIL=your-email@example.com
#   2. User ID-based (recommended): ADMIN_USER_ID=1
ADMIN_EMAIL=""
ADMIN_USER_ID=""
YOUTUBE_DATA_API_KEY=""
# YouTube API budget controls (10k units/day total; search.relatedToVideoId costs 100 units/call)
YOUTUBE_DAILY_QUOTA_UNITS="10000"
YOUTUBE_RELATED_DISCOVERY_RESERVED_UNITS="2500"
YOUTUBE_RELATED_DISCOVERY_DAILY_BUDGET_UNITS="3000"
ENABLE_AUTO_RELATED_BACKFILL="1"
AUTO_RELATED_BACKFILL_UNITS_PER_RUN="300"
AUTO_RELATED_BACKFILL_MIN_INTERVAL_MS="900000"
AUTO_RELATED_BACKFILL_MAX_NEWEST_OFFSET="0"
# Cron secret for /api/cron/related-backfill (leave empty to restrict to loopback only)
CRON_SECRET=""
GROQ_API_KEY=""
GROQ_MODEL="openai/gpt-oss-120b"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@example.com"

# Facebook group auto-share (automation)
FB_GROUP_AUTOSHARE_DRY_RUN="1"
FB_GROUP_ID=""
FB_GROUP_ACCESS_TOKEN=""
FB_GROUP_AUTOSHARE_MIN_INTERVAL_MINUTES="180"
FB_GROUP_AUTOSHARE_MAX_POSTS_PER_DAY="4"
FB_GROUP_AUTOSHARE_POOL_SIZE="600"
FB_GROUP_AUTOSHARE_DEDUPE_DAYS="30"
FB_GROUP_AUTOSHARE_STATE_PATH="logs/facebook-group-autoshare-state.json"

# Reddit subreddit auto-share (automation)
# Create a "script" type app at https://www.reddit.com/prefs/apps to get client_id and client_secret.
# The bot account must be a moderator of the target subreddit.
REDDIT_AUTOSHARE_DRY_RUN="1"
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USERNAME=""
REDDIT_PASSWORD=""
REDDIT_SUBREDDIT="YehThatRocks"
REDDIT_USER_AGENT=""
REDDIT_AUTOSHARE_MIN_INTERVAL_MINUTES="480"
REDDIT_AUTOSHARE_MAX_POSTS_PER_DAY="2"
REDDIT_AUTOSHARE_POOL_SIZE="600"
REDDIT_AUTOSHARE_DEDUPE_DAYS="60"
REDDIT_AUTOSHARE_STATE_PATH="logs/reddit-subreddit-autoshare-state.json"
