[Unit]
Description=YehThatRocks Magazine Article Autogen
After=network-online.target yehthatrocks.service
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=/srv/yehthatrocks/.env.production
ExecStart=/usr/bin/curl -fsS \
  -X POST \
  -H "Authorization: Bearer ${CRON_SECRET}" \
  "http://127.0.0.1:3000/api/cron/magazine-daily?count=1"
StandardOutput=journal
StandardError=journal
SyslogIdentifier=magazine-autogen
