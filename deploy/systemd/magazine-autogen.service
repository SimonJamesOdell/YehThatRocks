[Unit]
Description=YehThatRocks Magazine Article Autogen
After=network-online.target yehthatrocks.service
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/srv/yehthatrocks
EnvironmentFile=-/srv/yehthatrocks/.env.production
ExecStart=/usr/bin/bash -lc 'PORT="$${APP_PORT:-3000}"; COUNT="$${MAGAZINE_DAILY_COUNT:-1}"; CURL_TIMEOUT="$${MAGAZINE_DAILY_CURL_TIMEOUT_S:-900}"; URL="http://127.0.0.1:$${PORT}/api/cron/magazine-daily?count=$${COUNT}"; echo "[magazine-autogen] POSTing to $${URL} (curl timeout: $${CURL_TIMEOUT}s)"; if [ -n "$${CRON_SECRET:-}" ]; then /usr/bin/curl -fsSv --write-out "\n[magazine-autogen] HTTP %%{http_code}\n" --connect-timeout 10 --max-time "$${CURL_TIMEOUT}" -X POST -H "Authorization: Bearer $${CRON_SECRET}" "$${URL}"; else /usr/bin/curl -fsSv --write-out "\n[magazine-autogen] HTTP %%{http_code}\n" --connect-timeout 10 --max-time "$${CURL_TIMEOUT}" -X POST "$${URL}"; fi'
StandardOutput=journal
StandardError=journal
SyslogIdentifier=magazine-autogen
